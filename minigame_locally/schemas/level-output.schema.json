{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://feed-the-bear.local/schemas/level-output.schema.json",
  "title": "Feed the Bear Level Output",
  "description": "Target output schema for procedural level generation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "level",
    "board_size",
    "grid",
    "pairs",
    "blockers",
    "solution_count",
    "target_density",
    "golden_path",
    "validation",
    "meta"
  ],
  "properties": {
    "level": {
      "type": "integer",
      "minimum": 1,
      "maximum": 10
    },
    "board_size": {
      "type": "integer",
      "minimum": 4,
      "maximum": 6
    },
    "grid": {
      "type": "array",
      "minItems": 4,
      "maxItems": 6,
      "items": {
        "type": "array",
        "minItems": 4,
        "maxItems": 6,
        "items": {
          "type": "string",
          "pattern": "^(EMPTY|BLOCKED|OCCUPIED|NODE_[A-Z][12])$"
        }
      }
    },
    "pairs": {
      "type": "array",
      "minItems": 2,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "start", "end", "color"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[A-Z]$"
          },
          "start": {
            "$ref": "#/$defs/coord"
          },
          "end": {
            "$ref": "#/$defs/coord"
          },
          "color": {
            "type": "string",
            "pattern": "^#[0-9A-Fa-f]{6}$"
          }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/coord"
      }
    },
    "solution_count": {
      "type": "integer",
      "minimum": 1,
      "maximum": 20
    },
    "target_density": {
      "type": "string",
      "enum": [
        "HIGH",
        "MEDIUM-HIGH",
        "MEDIUM",
        "MEDIUM-LOW",
        "LOW",
        "VERY-LOW",
        "SINGLE",
        "LOW-MEDIUM"
      ]
    },
    "golden_path": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "minItems": 2,
        "items": {
          "$ref": "#/$defs/coord"
        }
      }
    },
    "validation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "solvable",
        "density_match",
        "early_mistake_detection",
        "no_isolated_pairs",
        "no_late_dead_ends",
        "curve_integrity"
      ],
      "properties": {
        "solvable": { "type": "boolean" },
        "density_match": { "type": "boolean" },
        "early_mistake_detection": { "type": "boolean" },
        "no_isolated_pairs": { "type": "boolean" },
        "no_late_dead_ends": { "type": "boolean" },
        "curve_integrity": { "type": "boolean" }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["generation_attempts", "failed_checks"],
      "properties": {
        "generation_attempts": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50
        },
        "failed_checks": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  },
  "$defs": {
    "coord": {
      "type": "array",
      "prefixItems": [
        { "type": "integer", "minimum": 0, "maximum": 5 },
        { "type": "integer", "minimum": 0, "maximum": 5 }
      ],
      "items": false,
      "minItems": 2,
      "maxItems": 2
    }
  }
}
